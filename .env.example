# ═══════════════════════════════════════════════════════════════════════════════
# MiLyfe Brain — Environment Configuration
# Copy this file to .env and adjust values for your deployment.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Core ─────────────────────────────────────────────────────────────────────
APP_NAME="MiLyfe Brain"
APP_VERSION=2.0.0
DEBUG=false

# ─── Server ───────────────────────────────────────────────────────────────────
BACKEND_PORT=8200
FRONTEND_PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
# SQLite (default) — for production consider PostgreSQL
DATABASE_URL=sqlite+aiosqlite:////data/milyfe.db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
REDIS_PORT=6479

# ─── Ollama / LLM ────────────────────────────────────────────────────────────
# Use host.docker.internal for Ollama running on host machine
OLLAMA_BASE_URL=http://host.docker.internal:11434
DEFAULT_LIGHT_MODEL=phi3:mini
DEFAULT_HEAVY_MODEL=llama3.1:8b
PREMIUM_MODEL=llama3.1:70b

# ─── ChromaDB (Vector Store) ─────────────────────────────────────────────────
CHROMADB_URL=http://chromadb:8000
CHROMA_PORT=8400

# ─── Agent Configuration ─────────────────────────────────────────────────────
MAX_AGENTS=10
AGENT_TIMEOUT=300
MAX_RETRIES=3
CONTEXT_SUMMARIZE_THRESHOLD=32000

# ─── Safety / Permissions ────────────────────────────────────────────────────
REQUIRE_APPROVAL_DESTRUCTIVE=true
REQUIRE_APPROVAL_BROWSING=true
REQUIRE_APPROVAL_GUI=true

# ─── Authentication ──────────────────────────────────────────────────────────
# Set AUTH_ENABLED=true and change the API key for production
AUTH_ENABLED=false
API_KEY=change-me-to-a-real-secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Set CORS_ALLOW_ALL=false in production and specify origins
CORS_ALLOW_ALL=true
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8200

# ─── Workspace ────────────────────────────────────────────────────────────────
WORKSPACE_DIR=/workspace
AUTO_GIT_SNAPSHOTS=true

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=text
LOG_DIR=/data/logs

# ─── Telemetry / Monitoring ──────────────────────────────────────────────────
OTEL_ENABLED=false
SENTRY_ENABLED=false
SENTRY_DSN=
METRICS_ENABLED=true

# ─── TLS ──────────────────────────────────────────────────────────────────────
TLS_ENABLED=false

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=120
MAX_REQUEST_SIZE_MB=10
