# MiLyfe Brain Configuration
# Copy to .env and customize

# Service Ports
CHROMA_PORT=8400
REDIS_PORT=6479
BACKEND_PORT=8200
FRONTEND_PORT=3000

# Ollama (runs on host, not in Docker)
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Models
DEFAULT_LIGHT_MODEL=phi3:mini
DEFAULT_HEAVY_MODEL=llama3.1:8b
PREMIUM_MODEL=llama3.1:70b

# Agent Limits
MAX_AGENTS=10
AGENT_TIMEOUT=300
MAX_RETRIES=3

# Safety / Approvals
REQUIRE_APPROVAL_DESTRUCTIVE=true
REQUIRE_APPROVAL_BROWSING=true
REQUIRE_APPROVAL_GUI=true

# Workspace
AUTO_GIT_SNAPSHOTS=true
WORKSPACE_DIR=/workspace

# Context Management
CONTEXT_SUMMARIZE_THRESHOLD=32000

# Auth (for network-exposed deployments)
AUTH_ENABLED=false
API_KEY=change-me-to-a-real-secret
CORS_ALLOW_ALL=true

# Database
DATABASE_URL=sqlite+aiosqlite:////data/milyfe.db

# AMD GPU (optional, for docker-compose.gpu.yml)
HSA_OVERRIDE_GFX_VERSION=10.3.0
