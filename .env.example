# ============================================================
# MiLyfe Brain - Environment Configuration
# ============================================================
# Copy this file to .env and update values as needed
# cp .env.example .env

# --- Service Ports ---
CHROMA_PORT=8400
REDIS_PORT=6479
BACKEND_PORT=8200
FRONTEND_PORT=3000

# --- LLM Configuration ---
OLLAMA_BASE_URL=http://host.docker.internal:11434
DEFAULT_LIGHT_MODEL=phi3:mini
DEFAULT_HEAVY_MODEL=llama3.1:8b
PREMIUM_MODEL=qwen2.5:14b

# --- Agent Configuration ---
MAX_AGENTS=10
AGENT_TIMEOUT=300
MAX_RETRIES=3

# --- Safety & Approval ---
REQUIRE_APPROVAL_DESTRUCTIVE=true
REQUIRE_APPROVAL_BROWSING=true
REQUIRE_APPROVAL_GUI=true

# --- Workspace ---
AUTO_GIT_SNAPSHOTS=true
WORKSPACE_DIR=/workspace
CONTEXT_SUMMARIZE_THRESHOLD=32000

# --- Auth & Security ---
AUTH_ENABLED=false
API_KEY=change-me-to-a-real-secret
CORS_ALLOW_ALL=true

# --- Database ---
DATABASE_URL=sqlite+aiosqlite:////data/milyfe.db
